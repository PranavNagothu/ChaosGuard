FROM golang:1.23-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /chaosguard-server ./cmd/server

FROM alpine:3.19
RUN apk --no-cache add ca-certificates tzdata
WORKDIR /app
COPY --from=builder /chaosguard-server /usr/local/bin/chaosguard-server
COPY dashboard/ ./dashboard/
EXPOSE 8080
ENTRYPOINT ["chaosguard-server"]

