FROM golang:1.23-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /chaosguard-agent ./cmd/agent

FROM alpine:3.19
RUN apk --no-cache add ca-certificates tzdata
COPY --from=builder /chaosguard-agent /usr/local/bin/chaosguard-agent
EXPOSE 8181
ENTRYPOINT ["chaosguard-agent"]
